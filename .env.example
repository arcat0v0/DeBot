# Telegram bot token from @BotFather (required to run the bot)
TELEGRAM_BOT_TOKEN=

# Comma or space separated Telegram user IDs allowed to use the bot.
# Get yours from @userinfobot. Empty means every user is rejected.
DEBOT_ALLOWED_USERS=

# Where encrypted profiles, presets and job history are stored.
DEBOT_DATA_DIR=./data

# Base64 of a 32-byte AES-256 master key used to encrypt credentials.
# Leave empty to auto-generate one into <DEBOT_DATA_DIR>/master.key (chmod 600).
DEBOT_MASTER_KEY=

# polling (default) or webhook.
DEBOT_MODE=polling

# Public HTTPS base URL when DEBOT_MODE=webhook, e.g. https://debot.example.com
DEBOT_PUBLIC_URL=

# Optional secret token validated on incoming Telegram webhook calls.
DEBOT_WEBHOOK_SECRET=

# HTTP listener for health checks and the webhook receiver.
DEBOT_HOST=0.0.0.0
DEBOT_PORT=8080

# debug | info | warn | error
DEBOT_LOG_LEVEL=info
