{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --env-file src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --env-file src/main.ts",
    "cli": "deno run --allow-net --allow-env --allow-read --allow-write --allow-run src/cli.ts",
    "compile": "deno compile --allow-net --allow-env --allow-read --allow-write --allow-run --output dist/debot src/cli.ts",
    "check": "deno check src/main.ts src/cli.ts",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli/parse-args": "jsr:@std/cli@1/parse-args",
    "@std/encoding/base64": "jsr:@std/encoding@1/base64",
    "@std/encoding/base64url": "jsr:@std/encoding@1/base64url",
    "@std/encoding/hex": "jsr:@std/encoding@1/hex",
    "@std/path": "jsr:@std/path@1",
    "@std/async": "jsr:@std/async@1"
  },
  "fmt": {
    "exclude": ["data", "coverage"]
  },
  "lint": {
    "exclude": ["data", "coverage"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
